#include <iostream>
using namespace std;

int main() {
    int pages, frames;
    cout << "Enter number of pages: ";
    cin >> pages;

    int page[pages];
    cout << "Enter page reference string:\n";
    for(int i = 0; i < pages; i++)
        cin >> page[i];

    cout << "Enter number of frames: ";
    cin >> frames;

    int frame[frames];
    for(int i = 0; i < frames; i++)
        frame[i] = -1;

    int index = 0, faults = 0;

    for(int i = 0; i < pages; i++) {
        bool found = false;
        for(int j = 0; j < frames; j++) {
            if(frame[j] == page[i]) {
                found = true;
                break;
            }
        }

        if(!found) {
            frame[index] = page[i];
            index = (index + 1) % frames;
            faults++;
        }
    }

    cout << "Total Page Faults: " << faults;
    return 0;
}
